# Copy to `.env` and adjust. All variables are optional; sensible defaults are baked in.
# Settings are read with the LCA_ prefix (see src/lca/config/settings.py).

# --- Inference engine (llama.cpp / llama-server, OpenAI-compatible endpoint) ---
LCA_LLM__BASE_URL=http://127.0.0.1:8080/v1
LCA_LLM__API_KEY=not-needed-for-local
# Active runtime profile: "quality" (30B-A3B brain) or "fast" (7B).
LCA_PROFILE=quality

# Model ids as registered in the engine (must match what llama-server / LM Studio reports).
LCA_LLM__BRAIN_MODEL=qwen3-coder-30b-a3b-instruct
LCA_LLM__FAST_MODEL=qwen2.5-coder-7b-instruct

# Context window cap (NOT the model's nominal max — 8GB VRAM tier should stay 8-16K).
LCA_LLM__MAX_CONTEXT_TOKENS=16384

# --- Autonomy / safety ---
# gated (default, approval-gated) | autonomous | plan
LCA_AUTONOMY=gated

# --- Web search (used by the search tool; the agent itself stays local) ---
# Optional Tavily key (failover only). Leave blank to use the local ddgs library.
LCA_SEARCH__TAVILY_API_KEY=
# Optional self-hosted SearXNG JSON endpoint (Docker power-up).
LCA_SEARCH__SEARXNG_URL=

# --- Logging ---
# console | json
LCA_LOG__FORMAT=console
LCA_LOG__LEVEL=INFO
